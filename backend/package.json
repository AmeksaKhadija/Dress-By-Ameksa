{
  "name": "dressbyme-backend",
  "version": "1.0.0",
  "description": "Backend - Dress by Ameksa",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "seed": "node seed.js",
    "test": "jest --verbose --forceExit --detectOpenHandles"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/tests/**/*.test.js"],
    "setupFiles": ["./tests/env.js"],
    "moduleNameMapper": {
      "^@gradio/client$": "<rootDir>/tests/__mocks__/gradioClient.js"
    }
  },
  "dependencies": {
    "@google/genai": "^1.43.0",
    "@gradio/client": "^2.1.0",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^1.41.0",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.0",
    "mongoose": "^7.0.0",
    "multer": "^2.0.0",
    "multer-storage-cloudinary": "^4.0.0",
    "nodemailer": "^6.9.1",
    "stripe": "^20.4.0"
  },
  "devDependencies": {
    "jest": "^30.2.0",
    "mongodb-memory-server": "^11.0.1",
    "nodemon": "^3.0.0",
    "supertest": "^7.2.2"
  }
}
